# Server
PORT=3000
NODE_ENV=development
API_KEY=

# Database
DB_CONNECTION=postgres://api@localhost:5432/api

# Redis
REDISCLOUD_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=node-clean-app
JWT_AUDIENCE=node-clean-app-client

# Jobs
JOB_CONCURRENCY=5
JOB_TIMEOUT=300000

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-4o-mini

# YouTube (optional)
YOUTUBE_API_KEY=
